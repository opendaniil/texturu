NODE_ENV=development
DEPLOY_ENV=development

ADMIN_SECRET_KEY=admin-secret-key

# WEB
WEB_PORT=80
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_API_HOST=http://localhost:3000

# API
