{
	"name": "@texturu/schemas",
	"version": "0.0.0",
	"private": true,
	"type": "commonjs",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"barrels": "barrelsby --config .barrelsby.json",
		"build": "pnpm run barrels && tsup",
		"dev": "pnpm run barrels && tsup --watch"
	},
	"dependencies": {
		"barrelsby": "^2.8.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	}
}
