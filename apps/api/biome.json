{
	"root": false,
	"extends": "//",
	"$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
	"javascript": {
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"linter": {
		"rules": {
			"style": {
				"useImportType": "off"
			}
		}
	},
	"files": {
		"includes": ["**", "!!src/infra/database/generated-db-types.ts"]
	},
	"overrides": [
		{
			"includes": ["src/infra/database/migrations/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
