{
	"name": "api",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"dev": "nodemon --config nodemon.json",
		"start:dev": "pnpm db:migrate && pnpm db:types && nest start",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"db:migrate": "kysely migrate latest",
		"db:types": "kysely-codegen",
		"db:make": "kysely migrate make"
	},
	"dependencies": {
		"@keyv/redis": "^5.1.6",
		"@mastra/ai-sdk": "^1.0.5",
		"@mastra/client-js": "^1.5.0",
		"@mastra/core": "^1.5.0",
		"@nestjs/axios": "^4.0.1",
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/cache-manager": "^3.1.0",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/schedule": "^6.1.1",
		"@nestjs/swagger": "^11.2.5",
		"@nestjs/terminus": "^11.0.0",
		"@sindresorhus/slugify": "^3.0.0",
		"@texturu/schemas": "workspace:*",
		"ai": "6.0.91",
		"axios": "^1.13.5",
		"bullmq": "^5.67.2",
		"cache-manager": "^7.2.8",
		"cookie-parser": "^1.4.7",
		"date-fns": "^4.1.0",
		"joi": "^18.0.2",
		"keyv": "^5.6.0",
		"kysely": "^0.28.11",
		"kysely-ctl": "^0.20.0",
		"nestjs-zod": "^5.1.1",
		"pg": "^8.17.2",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"subtitle": "^4.2.2",
		"uuid": "^13.0.0",
		"ytdlp-nodejs": "^3.4.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.10.13",
		"@types/pg": "^8.16.0",
		"@types/supertest": "^6.0.2",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"kysely-codegen": "^0.19.0",
		"prettier": "^3.4.2",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"moduleNameMapper": {
			"^src/(.*)$": "<rootDir>/$1"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
